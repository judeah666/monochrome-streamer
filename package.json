{
  "name": "monochrome-streamer",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "monochrome-streamer: a self-hosted music streamer for your own server files.",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node --watch server.mjs",
    "build": "npm run build:tailwind && vite build",
    "build:tailwind": "tailwindcss -i ./src/styles/tailwind.css -o ./public/tailwind.css --minify",
    "dev:tailwind": "tailwindcss -i ./src/styles/tailwind.css -o ./public/tailwind.css --watch",
    "dev:frontend": "vite --host 0.0.0.0",
    "test": "node --test",
    "verify": "npm test && npm run build"
  },
  "dependencies": {
    "music-metadata": "^11.12.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.35.1",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.0"
  }
}
