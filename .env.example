# Change this to your real music folder.
MUSIC_DIR=D:\Music

# Change this to where Monochrome-Streamer should save the database, lyrics, and cover cache.
APP_DATA_DIR=D:\Monochrome-Streamer\data

# Optional: change the title shown in the browser and sidebar.
APP_TITLE=Monochrome-Streamer

# Optional by default. Set these if you want to sign in as admin, or require them when NOAUTH=false.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Optional: guest browsing is enabled by default.
# You can still visit /login manually to sign in as admin or as a managed user.
NOAUTH=true

# Optional: only used when NOAUTH=true. Downloads are disabled for anonymous guests by default.
DOWNLOADS=false

# Optional: Linux server file ownership for Docker-created files.
PUID=1000
PGID=1000
UMASK=022
CHOWN_DATA=auto

# Optional: enable the external widget stats API with a real key and a specific browser origin.
WIDGET_API_KEY=
WIDGET_CORS_ORIGIN=
