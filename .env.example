# Change this to your real music folder.
MUSIC_DIR=D:\Music

# Change this to where Monochrome-Streamer should save the database, lyrics, and cover cache.
APP_DATA_DIR=D:\Monochrome-Streamer\data

# Optional: change the title shown in the browser and sidebar.
APP_TITLE=Monochrome-Streamer

# Required for the Admin sidebar tab and first login. Change both before exposing your server.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Optional: set NOAUTH=true to let everyone open the app without the login page.
# You can still visit /login manually to sign in as admin or as a managed user.
NOAUTH=false

# Optional: only used when NOAUTH=true. Set false to hide/disable downloads for anonymous guests.
DOWNLOADS=true

# Optional: Linux server file ownership for Docker-created files.
PUID=1000
PGID=1000
UMASK=022
CHOWN_DATA=true

# Optional: enable the external widget stats API.
WIDGET_API_KEY=change-this-widget-key
WIDGET_CORS_ORIGIN=*
