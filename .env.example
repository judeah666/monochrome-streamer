# Change this to your real music folder.
MUSIC_DIR=D:\Music

# Change this to where Monochrome-Streamer should save the database, lyrics, and cover cache.
APP_DATA_DIR=D:\Monochrome-Streamer\data

# Optional: change the title shown in the browser and sidebar.
APP_TITLE=Monochrome-Streamer

# Docker image tag used by docker-compose.yml.
IMAGE_TAG=0.1.0
